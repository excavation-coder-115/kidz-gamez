{
  "name": "kidz-gamez",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.13",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && bun run build:asset-budget",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "test": "bun test",
    "build:asset-budget": "bun scripts/check-asset-budget.mjs --dir dist --limit-mb 15",
    "perf:first-interactive": "bun scripts/measure-first-interactive.mjs --profile desktop-mid --budget-ms 2500"
  },
  "dependencies": {
    "three": "^0.176.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
