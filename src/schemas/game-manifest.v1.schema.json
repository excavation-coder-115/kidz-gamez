{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kidz-gamez.local/schemas/game-manifest.v1.schema.json",
  "title": "GameManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "route",
    "description",
    "tags",
    "ageBand",
    "cabinetType",
    "vehicleSupport",
    "launchMode"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "route": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ageBand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0, "maximum": 18 },
        "max": { "type": "integer", "minimum": 0, "maximum": 18 }
      }
    },
    "cabinetType": {
      "type": "string",
      "enum": ["racing", "puzzle", "builder", "arcade"]
    },
    "vehicleSupport": {
      "type": "string",
      "enum": ["required", "optional", "none"]
    },
    "launchMode": {
      "type": "string",
      "enum": ["seamless", "load-screen"]
    }
  }
}
